<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Atelier" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const saved = localStorage.getItem("phx:theme");
        if (saved) {
          document.documentElement.setAttribute("data-theme", saved);
        }

        // When DOM is ready, sync the radio button to match the saved theme
        document.addEventListener("DOMContentLoaded", () => {
          const saved = localStorage.getItem("phx:theme");
          if (saved) {
            const radio = document.querySelector(`input.theme-controller[value="${saved}"]`);
            if (radio) radio.checked = true;
          }
        });

        // Persist theme on radio change and sync to iframes
        document.addEventListener("change", (e) => {
          if (e.target.classList.contains("theme-controller")) {
            const theme = e.target.value;
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.querySelectorAll("iframe").forEach((f) => {
              f.contentWindow?.postMessage({type: "theme-change", theme: theme}, "*");
            });
          }
        });

        // Preview-only theme selector: only updates iframes
        document.addEventListener("change", (e) => {
          if (e.target.classList.contains("preview-theme")) {
            const theme = e.target.value;
            document.querySelectorAll("iframe").forEach((f) => {
              f.contentWindow?.postMessage({type: "theme-change", theme: theme}, "*");
            });
          }
        });

        // Multi-tab sync
        window.addEventListener("storage", (e) => {
          if (e.key === "phx:theme" && e.newValue) {
            document.documentElement.setAttribute("data-theme", e.newValue);
            const radio = document.querySelector(`input.theme-controller[value="${e.newValue}"]`);
            if (radio) radio.checked = true;
          }
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
