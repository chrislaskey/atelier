defmodule <%= @module_name %> do
  use AtelierWeb, :live_component

  @moduledoc """
  Generated by Atelier
  """

  @atelier %{
    name: <%= inspect(@name) %>,
    html: <%= inspect(@html) %>,
    prompt: <%= inspect(@prompt) %>,
    model: <%= inspect(@model) %>,
    updated_at: <%= inspect(@updated_at) %>
  }

  <%= @elixir %>

  def __atelier__, do: @atelier
end
